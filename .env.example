# Required: GitHub App numeric ID.
GH_APP_ID=

# Optional: local port for the Express server.
PORT=3000

# Required for ngrok tunneling.
# Get or rotate it at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Missing outside this file:
# - private-key.pem must exist in the project root.
# - The GitHub App webhook URL must point to: https://<your-ngrok-domain>/hook